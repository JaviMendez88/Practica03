@model Practica03.EntityFramework.AbonosTB

@{
    ViewData["Title"] = "Abonos";
    Layout = "~/Views/Shared/_LayoutExterno.cshtml";
}

<div class="card shadow-sm p-4" style="min-width: 400px;">
    <h3 class="text-center mb-3">Gestión de Abonos</h3>

    @using (Html.BeginForm("Create", "Abonos", FormMethod.Post))
    {
        <div class="mb-3">
            <label>Compra</label>
            @Html.DropDownList("IdCompra", (SelectList)ViewBag.Compras, "--Seleccione--", new { @class = "form-control", id = "IdCompra" })
        </div>

        <div class="mb-3">
            <label>Saldo Anterior</label>
            <input type="text" id="SaldoAnterior" class="form-control" readonly />
        </div>

        <div class="mb-3">
            <label>Monto Abono</label>
            @Html.TextBoxFor(m => m.MontoAbono, new { @class = "form-control", required = "required" })
        </div>

        <button type="submit" class="btn btn-primary w-100">Abonar</button>
    }
</div>

<script src="~/Assets/js/Compras.js"></script>