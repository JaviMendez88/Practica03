@model IEnumerable<Practica03.EntityFramework.PrincipalTB>

@{
    ViewData["Title"] = "Consulta de Compras";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card shadow-sm p-4">
    <h3 class="mb-3">Consulta del Principal de saldos</h3>

    <table class="table table-hover table-bordered align-middle">
        <thead class="table-dark text-center">
            <tr>
                <th>ID</th>
                <th>Descripción</th>
                <th>Monto Total</th>
                <th>Saldo</th>
                <th>Estado</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="text-center">
                    <td>@item.IdCompra</td>
                    <td class="text-start">@item.Descripcion</td>
                    <td>@item.MontoTotal.ToString("C")</td>
                    <td>@item.Saldo.ToString("C")</td>
                    <td>
                        <span class="badge @(item.Estado == "Pendiente" ? "bg-warning text-dark" : "bg-success")">
                            @item.Estado
                        </span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
